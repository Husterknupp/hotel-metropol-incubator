# Copy to .env and fill in real values. .env is gitignored — never commit it.
# See README.md "Configuration" for the full list of variables and defaults.

# Required for untrusted-actor warnings to reach you (no default on purpose —
# these identify a specific person/channel, see src/openclaw-adapter.js).
OPENCLAW_WARN_REPLY_CHANNEL=discord
OPENCLAW_WARN_REPLY_TO=user:<your-discord-user-id>
